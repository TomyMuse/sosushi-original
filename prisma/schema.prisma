// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Admin user for panel access
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  role      String    @default("admin")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Menu categories
model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  order       Int       @default(0)
  emoji       String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Products in the menu
model Product {
  id          String        @id @default(cuid())
  name        String
  description String?
  image       String?
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  sizes       ProductSize[]
  isActive    Boolean       @default(true)
  isPopular   Boolean       @default(false)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([categoryId])
}

// Product sizes with prices (x5, x10, x12, etc.)
model ProductSize {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String  // e.g., "x5", "x10", "x12"
  pieces    Int     // number of pieces
  price     Float   // price in ARS
  order     Int     @default(0)
  
  @@index([productId])
}

// Customer orders
model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  customerName    String
  customerPhone   String
  customerAddress String
  observations    String?
  subtotal        Float
  discountAmount  Float         @default(0)
  total           Float
  status          String        @default("pending") // pending, paid, preparing, delivered, cancelled
  paymentMethod   String        // mercadopago, transfer
  paymentStatus   String        @default("pending") // pending, approved, rejected
  paymentId       String?       // Mercado Pago payment ID
  discountId      String?
  discount        Discount?     @relation(fields: [discountId], references: [id])
  items           OrderItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Items within an order
model OrderItem {
  id           String       @id @default(cuid())
  orderId      String
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  productName  String
  sizeLabel    String
  pieces       Int
  unitPrice    Float
  quantity     Int
  subtotal     Float
  observations String?
  createdAt    DateTime     @default(now())

  @@index([orderId])
}

// Discount codes
model Discount {
  id          String    @id @default(cuid())
  code        String    @unique
  type        String    // percentage, fixed
  value       Float     // percentage value or fixed amount
  minOrder    Float?    // minimum order amount
  maxUses     Int?      // maximum number of uses (null = unlimited)
  currentUses Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  orders      Order[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Payment records
model Payment {
  id              String   @id @default(cuid())
  orderId         String
  orderNumber     String
  amount          Float
  method          String   // mercadopago, transfer
  status          String   // pending, approved, rejected, refunded
  externalRef     String?  // Mercado Pago payment ID or transfer reference
  metadata        String?  // JSON string for additional data
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orderId])
  @@index([status])
}
